with "../czmq_ada.gpr";

project Tests is
   for Source_Dirs use (".");
   for Object_Dir use "obj";
   for Exec_Dir use ".";
   for Main use ("test_certificates.adb",
                  "test_sockets_curve.adb",
                  "test_authentication.adb");

   package Compiler renames CZMQ_Ada.Compiler;
   package Binder renames CZMQ_Ada.Binder;
end Tests;
